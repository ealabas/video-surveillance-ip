# === Camera Settings ===
CAMERA_DEVICE=video=HD Webcam
CAMERA_FORMAT=dshow
PIXEL_FORMAT=yuyv422

# === Audio Settings (optional) ===
AUDIO_DEVICE=audio=Mikrofon (USB Pro Audio)

# === Encoding Settings ===
RESOLUTION=640x480
FRAMERATE=30
VIDEO_BITRATE=7000k
SEGMENT_DURATION=6

# Buffer Settings (0 = keep all segments from start)
WINDOW_SIZE=0
EXTRA_WINDOW_SIZE=0

# === Output Settings ===
OUTPUT_DIR=.\server\dash_output
MANIFEST_NAME=stream.mpd

# === Server Settings ===
HTTP_PORT=9090
SERVER_HOST=0.0.0.0
